# Facebook login (optional — leave empty for manual login)
FB_EMAIL=
FB_PASSWORD=

# Browser
BROWSER_HEADLESS=false
BROWSER_PROFILE_DIR=./data/chrome_profile
CHROME_CHANNEL=chrome

# Proxy (optional — leave empty to disable)
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=

# Search defaults
SEARCH_LOCATION=seattle
SEARCH_QUERY=
SEARCH_MIN_PRICE=
SEARCH_MAX_PRICE=
SEARCH_SORT_BY=creation_time_descend
SEARCH_DAYS_LISTED=

# Scraper behavior
MIN_DELAY=5.0
MAX_DELAY=12.0
MAX_LISTINGS=100
SCROLL_PAUSE=3.0

# Output
OUTPUT_DIR=./data/raw

# Deal finder — API keys
ANTHROPIC_API_KEY=
REVERB_API_TOKEN=

# Deal finder — models and thresholds
DEAL_SCORE_THRESHOLD=0.30
IDENTIFIER_MODEL=claude-haiku-4-5-20251001
EVALUATOR_MODEL=claude-sonnet-4-5-20250929
MAX_EVAL_CONCURRENCY=5

# Telegram notifications (optional — for --notify-telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
